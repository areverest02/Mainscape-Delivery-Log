{
  "version": 2,
  "builds": [
    { "src": "api/api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/auth/(.*)", "dest": "api/api/index.js" },
    { "src": "/api/(.*)", "dest": "api/api/index.js" },
    { "src": "/callback", "dest": "api/api/index.js" },
    { "src": "/(.*)", "dest": "api/api/index.js" }
  ]
}
